# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/streamvibe

# JWT (generate strong random strings, e.g. openssl rand -base64 32)
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Client & API URLs (for CORS and activation links)
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# Email verification (optional – signup works without; activation link is logged)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
